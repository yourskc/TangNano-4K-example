`timescale 100 ps/100 ps
module video_top (
  clk,
  rst_n,
  key,
  led_o
)
;
input clk;
input rst_n;
input [1:0] key;
output led_o;
wire VCC;
wire GND;
  OBUF led_o_obuf (
    .O(led_o),
    .I(VCC) 
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* video_top */
